# echada CLI test fixtures (Fixtures/test1..3): these are input harnesses for the
# real binary — only the episode scripts are tracked. Everything the CLI writes
# into them (PROJECT.md, voices/, *.vox, etc.) is intentionally left untracked.
Fixtures/test1/*
Fixtures/test2/*
Fixtures/test3/*
!Fixtures/test1/episodes/
!Fixtures/test2/episodes/
!Fixtures/test3/episodes/

# graphify codemap: commit the portable graph artifacts, ignore machine-specific
# markers (absolute paths), the regenerable cache, and the absolute-path manifest.
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_detect.json
graphify-out/cache/
graphify-out/manifest.json
